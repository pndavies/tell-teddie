@rendermode InteractiveServer
@using TellTeddie.Web.Components.Forms

<div class="modal @(IsVisible ? "show" : "")" tabindex="-1" style="@ModalDisplayStyle">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Create a Post</h5>
                <button type="button" class="btn-close" @onclick="Close" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <ul class="nav nav-tabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link @(activeTab == "audio" ? "active" : "")" 
                                @onclick="@(() => SetActiveTab("audio"))" 
                                type="button" 
                                role="tab">
                            Audio Post
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link @(activeTab == "text" ? "active" : "")" 
                                @onclick="@(() => SetActiveTab("text"))" 
                                type="button" 
                                role="tab">
                            Text Post
                        </button>
                    </li>
                </ul>
                
                <div class="tab-content mt-3">
                    <div class="tab-pane @(activeTab == "audio" ? "active show" : "")" role="tabpanel">
                        @if (activeTab == "audio")
                        {
                            <AudioForm OnPostSubmitted="HandlePostSubmitted"></AudioForm>
                        }
                    </div>
                    <div class="tab-pane @(activeTab == "text" ? "active show" : "")" role="tabpanel">
                        @if (activeTab == "text")
                        {
                            <TextForm OnPostSubmitted="HandlePostSubmitted"></TextForm>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (IsVisible)
{
    <div class="modal-backdrop show"></div>
}

@code {
    [Parameter]
    public bool IsVisible { get; set; }
    
    [Parameter]
    public EventCallback<bool> IsVisibleChanged { get; set; }
    
    [Parameter]
    public EventCallback OnPostSubmitted { get; set; }
    
    private string activeTab = "audio";
    
    private string ModalDisplayStyle => IsVisible ? "display: block" : "display: none";
    
    private void SetActiveTab(string tab)
    {
        activeTab = tab;
    }
    
    private async Task Close()
    {
        IsVisible = false;
        await IsVisibleChanged.InvokeAsync(IsVisible);
    }
    
    private async Task HandlePostSubmitted()
    {
        // Close the modal after successful submission
        await Close();
        
        // Notify parent component
        await OnPostSubmitted.InvokeAsync();
    }
}
