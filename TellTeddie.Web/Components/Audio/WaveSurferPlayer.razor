@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="wavesurfer-player">
    <div id="@_containerId" class="waveform-container"></div>
    <div class="player-controls">
        <button class="control-btn" @onclick="PlayPause" disabled="@(!isReady)">
            @if (isPlaying)
            {
                <span>⏸️</span>
            }
            else
            {
                <span>▶️</span>
            }
        </button>
        <button class="control-btn" @onclick="Stop" disabled="@(!isReady)">
            <span>⏹️</span>
        </button>
    </div>
</div>

@code {
    [Parameter]
    public string AudioUrl { get; set; } = string.Empty;

    [Parameter]
    public string? Title { get; set; }

    private string _containerId = $"wavesurfer-{Guid.NewGuid():N}";
    private bool isReady = false;
    private bool isPlaying = false;
    private System.Timers.Timer? statusTimer;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !string.IsNullOrEmpty(AudioUrl))
        {
            try
            {
                isReady = await JS.InvokeAsync<bool>("wavesurferPlayer.init", _containerId, AudioUrl);
                
                if (isReady)
                {
                    // Start a timer to check playing status
                    statusTimer = new System.Timers.Timer(500);
                    statusTimer.Elapsed += async (s, e) =>
                    {
                        await InvokeAsync(async () =>
                        {
                            try
                            {
                                var playing = await JS.InvokeAsync<bool>("wavesurferPlayer.isPlaying", _containerId);
                                if (playing != isPlaying)
                                {
                                    isPlaying = playing;
                                    StateHasChanged();
                                }
                            }
                            catch { }
                        });
                    };
                    statusTimer.Start();
                }
                
                StateHasChanged();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error initializing WaveSurfer: {ex.Message}");
            }
        }
    }

    private async Task PlayPause()
    {
        if (isReady)
        {
            try
            {
                await JS.InvokeVoidAsync("wavesurferPlayer.playPause", _containerId);
                isPlaying = !isPlaying;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error toggling playback: {ex.Message}");
            }
        }
    }

    private async Task Stop()
    {
        if (isReady)
        {
            try
            {
                await JS.InvokeVoidAsync("wavesurferPlayer.stop", _containerId);
                isPlaying = false;
                StateHasChanged();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error stopping playback: {ex.Message}");
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        statusTimer?.Stop();
        statusTimer?.Dispose();

        if (isReady)
        {
            try
            {
                await JS.InvokeVoidAsync("wavesurferPlayer.destroy", _containerId);
            }
            catch { }
        }
    }
}
