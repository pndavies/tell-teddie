{
  "$schema": "http://json.schemastore.org/launchsettings.json",
    "iisSettings": {
      "windowsAuthentication": false,
      "anonymousAuthentication": true,
      "iisExpress": {
        "applicationUrl": "http://localhost:60781",
        "sslPort": 44314
      }
    },
    "profiles": {
      "Development (Docker SQL)": {
        "commandName": "Project",
        "dotnetRunMessages": true,
        "launchBrowser": true,
        "applicationUrl": "https://localhost:7222;http://localhost:5039",
        "environmentVariables": {
          "ASPNETCORE_ENVIRONMENT": "Development"
        }
      },
      "Development (SQLEXPRESS)": {
        "commandName": "Project",
        "dotnetRunMessages": true,
        "launchBrowser": true,
        "applicationUrl": "https://localhost:7222;http://localhost:5039",
        "environmentVariables": {
          "ASPNETCORE_ENVIRONMENT": "Development",
          "ConnectionStrings__tellTeddieLocalDbConnectionString": "Server=localhost\\SQLEXPRESS;Database=TellTeddieTest;Trusted_Connection=True;TrustServerCertificate=True;"
        }
      },
      "Docker (Full Stack for Container Testing)": {
        "commandName": "Docker",
        "launchBrowser": true,
        "launchUrl": "{Scheme}://{ServiceHost}:{ServicePort}",
        "environmentVariables": {
          "ASPNETCORE_ENVIRONMENT": "Docker"
        },
        "publishAllPorts": true,
        "useSSL": false
      },
      "IIS Express": {
        "commandName": "IISExpress",
        "launchBrowser": true,
        "environmentVariables": {
          "ASPNETCORE_ENVIRONMENT": "Development"
        }
      }
    }
  }
